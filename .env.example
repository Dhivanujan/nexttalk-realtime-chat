# Server Environment Variables (Put these in server/.env)
PORT=5000
MONGODB_URI="mongodb://127.0.0.1:27017/chat-app-db"
JWT_SECRET="your_super_secret_jwt_key"
CLIENT_URL="http://localhost:5173"

# Web Push Notifications (Generated via 'npx web-push generate-vapid-keys')
VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"

# Client Environment Variables (Put these in client/.env)
VITE_API_URL="http://localhost:5000/api"
VITE_VAPID_PUBLIC_KEY="your_vapid_public_key"
